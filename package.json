{
  "name": "inspirasjonsdag",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/generate-sw.ts && next dev",
    "build": "prisma generate && tsx scripts/generate-sw.ts && next build",
    "generate-sw": "tsx scripts/generate-sw.ts",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:clear-feedback": "tsx --env-file=.env.local scripts/clear-feedback.ts",
    "db:update-details": "tsx --env-file=.env.local scripts/update-session-details.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx --env-file=.env.local prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "next": "^15.5.19",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20.19.43",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
